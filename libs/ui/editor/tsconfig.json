    "jsx": "react-jsx",
    "allowJs": false,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "jsxImportSource": "@emotion/react",
    "types": []
  },
  "files": [],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "extends": "../../../tsconfig.base.json",

{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/website/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/website/jest.config.ts"
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook dev --port 4400 --config-dir libs/website/.storybook"
      },
      "configurations": {
        "ci": {
          "command": "storybook dev --port 4400 --config-dir libs/website/.storybook --quiet"
        }
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/storybook/website"],
      "options": {
        "command": "storybook build --config-dir libs/website/.storybook --output-dir dist/storybook/website"
      },
      "configurations": {
        "ci": {
          "command": "storybook build --config-dir libs/website/.storybook --output-dir dist/storybook/website --quiet"
        }
      }
    }
  }
}

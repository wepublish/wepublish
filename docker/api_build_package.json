{
  "name": "api",
  "pkg": {
    "assets": [
      "node_modules/axios/dist/node/axios.cjs",
      "node_modules/es-get-iterator/node.js",
      "node_modules/i18n-iso-countries/langs",
      "node_modules/@node-rs/bcrypt-linux-x64-gnu/**/*",
      "node_modules/@node-rs/argon2-linux-x64-gnu/**/*"
    ],
    "publicPackages": [
      "@node-rs/argon2-linux-x64-gnu",
      "@node-rs/bcrypt-linux-x64-gnu"
    ],
    "ignore": [
      "@prisma/client",
      "@prisma/adapter-pg",
      ".prisma",
      "pg",
      "pg-pool",
      "pg-protocol",
      "pg-types",
      "pg-connection-string"
    ],
    "targets": ["node22-linux"]
  },
  "bin": {
    "main": "dist/apps/api-example/main.js"
  }
}
